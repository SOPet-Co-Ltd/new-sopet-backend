{
  "name": "sopet-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "preinstall": "npx only-allow yarn",
    "build": "nest build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli",
    "migration:generate": "yarn typeorm migration:generate -d ormconfig.ts",
    "migration:create": "yarn typeorm migration:create",
    "migration:run": "yarn typeorm migration:run -d ormconfig.ts",
    "seed": "yarn db:seed:dev",
    "db:reset": "yarn db:reset:dev",
    "db:reset:dev": "ts-node -r tsconfig-paths/register src/database/seeds/reset-db.ts && yarn db:seed:dev",
    "db:seed:dev": "ts-node -r tsconfig-paths/register src/database/seeds/seed-dev.ts",
    "db:seed:prod": "ts-node -r tsconfig-paths/register src/database/seeds/seed-prod.ts",
    "migration:revert": "yarn typeorm migration:revert -d ormconfig.ts",
    "schema:sync": "yarn typeorm schema:sync -d ormconfig.ts",
    "schema:drop": "yarn typeorm schema:drop -d ormconfig.ts",
    "graphql:schema": "node scripts/ensure-graphql-schema.mjs",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:reset": "docker compose down -v",
    "docker:ps": "docker compose ps",
    "docker:check": "docker compose ps && docker compose exec -T postgres pg_isready -U postgres -d sopet_ecommerce && docker compose exec -T redis redis-cli ping && curl -sf http://localhost:9000/minio/health/live"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/express5": "^1.1.2",
    "@aws-sdk/client-s3": "^3.1078.0",
    "@nestjs/apollo": "^13.0.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/graphql": "^13.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/typeorm": "^10.0.1",
    "@scalar/nestjs-api-reference": "^1.2.7",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.79.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dataloader": "^2.2.3",
    "dotenv": "^16.3.1",
    "graphql": "^16.11.0",
    "graphql-subscriptions": "^3.0.0",
    "ioredis": "^5.11.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.16.0",
    "rxjs": "^7.8.1",
    "sharp": "^0.35.3",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/sharp": "^0.32.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": "prettier --write"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "modules/orders/orders.service.ts",
      "modules/auth/auth.service.ts",
      "modules/products/products.service.ts",
      "modules/stores/stores.service.ts",
      "modules/payouts/payouts.service.ts",
      "modules/payouts/payout-scheduler.service.ts",
      "modules/cart/cart.service.ts",
      "modules/payments/payments.service.ts",
      "modules/promotions/promotions.service.ts"
    ],
    "coverageDirectory": "../coverage",
    "coverageThreshold": {
      "global": {
        "branches": 65,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testEnvironment": "node"
  }
}
