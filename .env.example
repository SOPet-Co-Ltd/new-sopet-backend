# =============================================================================
# SOPET Backend — environment variables
# Local stack: `yarn docker:up` → `yarn migration:run` → `yarn start:dev`
# =============================================================================

# --- Application ---
NODE_ENV=development
PORT=3002

# --- PostgreSQL (docker service: postgres) ---
# Local reset: `yarn db:reset:migrate` (drop + migrate, no seed) or `yarn db:reset:dev` (+ dev seed)
# UAT/prod reset (destructive): DB_RESET_ALLOW_PRODUCTION=1 yarn db:reset:migrate
# Prod bootstrap: `yarn db:seed:prod` (admin only, idempotent; default password P@ssw0rd)
# PROD_ADMIN_EMAIL=admin@sopet.org
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=sopet_ecommerce
DB_SSL=false
DB_POOL_MAX=20

# --- Redis (optional — omit REDIS_HOST to disable cache and background job queues) ---
# Local stack includes redis via `yarn docker:up`
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- MinIO / S3 (docker services: minio, minio-init) ---
# Console: http://localhost:9001 (minioadmin / minioadmin)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=sopet-ecommerce-files
# Custom S3-compatible endpoint (MinIO/R2). Leave empty for real AWS S3.
AWS_S3_ENDPOINT=http://localhost:9000
# Required true for MinIO (path-style requests: <endpoint>/<bucket>/<key>).
AWS_S3_FORCE_PATH_STYLE=true
# Base URL used to build the returned public object URL.
AWS_S3_PUBLIC_URL=http://localhost:9000/sopet-ecommerce-files
# Optional canned ACL applied per-object (e.g. public-read). Leave empty to
# rely on a bucket policy for public read — MinIO's default here grants public
# download via `mc anonymous set download` (see docker-compose minio-init).
AWS_S3_OBJECT_ACL=
CDN_URL=

# Production AWS S3 — replace MinIO block above:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_ENDPOINT=
# AWS_S3_FORCE_PATH_STYLE=false
# AWS_S3_PUBLIC_URL=https://cdn.example.com
# AWS_S3_OBJECT_ACL=public-read   # only if the bucket allows object ACLs

# Cloudflare R2 — set STORAGE_PROVIDER=r2 and fill (endpoint is derived from
# the account id; public URL comes from CDN_URL):
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_ACCESS_KEY_ID=
# CLOUDFLARE_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET=
# CDN_URL=https://<your-r2-public-domain>

# --- JWT ---
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- SMS / OTP (ThaiBulkSMS per PRD; Twilio fallback) ---
THAIBULKSMS_API_KEY=
THAIBULKSMS_API_SECRET=
THAIBULKSMS_SENDER=SOPet
THAIBULKSMS_FORCE=corporate
THAIBULKSMS_SHORTEN_URL=false
# UAT/testing only: log OTP to server logs without sending SMS (never enable in production)
SMS_OTP_LOG_ONLY=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Omise (Thailand payments) ---
OMISE_PUBLIC_KEY=
OMISE_SECRET_KEY=
OMISE_WEBHOOK_SECRET=

# --- QR payment expiry ---
# PromptPay QR validity window in minutes (default: 15)
PAYMENT_QR_EXPIRY_MINUTES=15
# Background expiry check interval in milliseconds (default: 30000)
PAYMENT_EXPIRY_CHECK_INTERVAL_MS=30000

# --- Email (Resend — https://resend.com) ---
RESEND_API_KEY=
EMAIL_FROM=noreply@sopet.co.th
EMAIL_FROM_NAME=SOPet Marketplace

# --- Frontend URLs (links in emails, redirects) ---
STOREFRONT_URL=http://localhost:3000
ADMIN_PANEL_URL=http://localhost:3001

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Rate limiting ---
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# --- Smart Search (Postgres-native FTS + hybrid retrieval) ---
# Set true after Phase 1 wiring to enable SearchService path (default: ILIKE fallback)
SEARCH_SMART_ENABLED=false
# OpenAI embeddings for semantic leg (Phase 3); required for embedding worker only
OPENAI_API_KEY=

# --- Payout scheduler (BullMQ repeatable job) ---

# --- Reviews ---
# Deprecated: reviews are always approved on create (vendor-reply release). This env var is ignored.
REVIEW_AUTO_APPROVE=true
# Days after delivery that customers can submit a review (default 30)
REVIEW_WINDOW_DAYS=30
# Cron pattern (default: daily at 02:00 Asia/Bangkok)
PAYOUT_CRON_SCHEDULE=0 2 * * *
PAYOUT_CRON_TIMEZONE=Asia/Bangkok
PAYOUT_MIN_AMOUNT=500
